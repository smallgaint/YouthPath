{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://youthpath/policy_agent_response.schema.json",
  "title": "Policy Agent Response",
  "description": "YouthPath Policy Agent의 최종 출력. 공통 외피(agent_name/items/sources/metadata/error)는 모든 Agent 공유, items 내부 키는 policy 도메인 전용.",
  "type": "object",
  "required": ["agent_name", "items", "sources", "metadata", "error"],
  "additionalProperties": false,
  "properties": {
    "agent_name": {
      "const": "policy",
      "description": "Agent 식별자. Router가 도메인별 포맷터를 고르는 데 사용."
    },
    "items": {
      "type": "array",
      "description": "score 임계값을 통과한 정책 목록. score 내림차순 정렬.",
      "items": { "$ref": "#/$defs/policyItem" }
    },
    "sources": {
      "type": "array",
      "description": "이번 응답에 실제 사용된 데이터 소스만 나열.",
      "items": {
        "type": "string",
        "enum": ["온통청년 getPlcy API", "Chroma policies"]
      }
    },
    "metadata": { "$ref": "#/$defs/metadata" },
    "error": {
      "type": ["string", "null"],
      "description": "정상이면 null. 부분 실패 시 사람이 읽을 메시지(예: 'API timeout, RAG-only 결과')."
    }
  },
  "$defs": {
    "policyItem": {
      "type": "object",
      "required": [
        "policy_id", "title", "summary", "benefit",
        "region_label", "category", "keywords", "host_org",
        "deadline", "deadline_type", "deadline_raw",
        "score", "matched_criteria", "unmatched_criteria", "other_conditions",
        "apply_method", "exclusion", "link", "source"
      ],
      "additionalProperties": false,
      "properties": {
        "policy_id": {
          "type": "string",
          "description": "온통청년 정책 고유 ID(plcyNo/DOCID). dedup·Calendar 흡수·카드 key.",
          "examples": ["20260409005400212660"]
        },
        "title": {
          "type": "string",
          "description": "정책명. raw.plcyNm/PLCY_NM에서 HTML 태그 제거.",
          "examples": ["울릉섬 청년 주거비 지원사업"]
        },
        "summary": {
          "type": "string",
          "description": "카드 본문용 1~2문장 요약. plcyExplnCn 정제 후 첫 80자 내외.",
          "examples": ["19~49세 무주택 1인가구 청년에게 월 최대 20만원, 1년 지원"]
        },
        "benefit": {
          "type": "string",
          "description": "지원 내용(얼마/무엇). raw.plcySprtCn 정제. 비었으면 빈 문자열.",
          "examples": ["1년 지원, 월 최대 20만원(신혼부부 30만원) 지급"]
        },
        "region_label": {
          "type": "string",
          "description": "사람이 읽는 지역명. region이 법정동 코드면 시도명으로 변환, CSV면 '첫 지역 외 N곳'.",
          "examples": ["경상북도 울릉군", "충청남도 천안시 외 13곳", "전국"]
        },
        "category": {
          "type": "string",
          "description": "대분류로 통일(lclsfNm 기준).",
          "examples": ["주거", "일자리", "복지문화", "교육", "참여권리"]
        },
        "keywords": {
          "type": "array",
          "description": "정책 키워드. raw.plcyKywdNm를 콤마로 분리, HTML 태그 제거.",
          "items": { "type": "string" },
          "examples": [["주거지원", "대출", "보조금"]]
        },
        "host_org": {
          "type": "string",
          "description": "소관/주관 기관. raw.sprvsnInstCdNm. 신뢰도·문의처.",
          "examples": ["경상북도 울릉군 미래전략과"]
        },
        "deadline": {
          "type": ["string", "null"],
          "format": "date",
          "description": "ISO-8601(YYYY-MM-DD) 신청 마감일. 상시/미정/파싱 실패는 null.",
          "examples": ["2026-04-30", null]
        },
        "deadline_type": {
          "type": "string",
          "enum": ["마감일", "상시", "미정"],
          "description": "마감일=확정 날짜 있음, 상시=APLY_PRD_SE_CD가 상시, 미정=정보 없음."
        },
        "deadline_raw": {
          "type": "string",
          "description": "원본 마감 문자열 보존(디버깅·검증용).",
          "examples": ["20260413 ~ 20260430", "상시", "0", ""]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "자격 적합도 0~1. 현재 age(0.4)+region(0.3)+income(0.3) 가중합. 입력 프로필이 다양해지면 가중치 재설계 예정.",
          "examples": [0.85]
        },
        "matched_criteria": {
          "type": "array",
          "description": "프로필로 판정 가능했고 충족한 자격 조건.",
          "items": { "$ref": "#/$defs/criterion" }
        },
        "unmatched_criteria": {
          "type": "array",
          "description": "프로필로 판정 가능했으나 미충족, 또는 프로필 값이 없어 확인 불가한 자격 조건.",
          "items": { "$ref": "#/$defs/criterion" }
        },
        "other_conditions": {
          "type": "array",
          "description": "정책이 요구하지만 현재 프로필로 판정하지 않는 조건(결혼/학력/취업상태/전공/특화분야 등 + 기타 자격 문구). 점수에는 반영 안 함. 카드·통합 LLM이 참고용으로 표시. 입력 프로필이 확장되면 일부는 matched/unmatched로 승격.",
          "items": { "$ref": "#/$defs/otherCondition" }
        },
        "apply_method": {
          "type": "string",
          "description": "신청 방법. raw.plcyAplyMthdCn 정제. '구체적 다음 단계' 안내에 사용.",
          "examples": ["복지로(www.bokjiro.go.kr) 온라인 신청 또는 읍·면·동 행정복지센터 방문"]
        },
        "exclusion": {
          "type": ["string", "null"],
          "description": "신청 제외 대상. raw.ptcpPrpTrgtCn 정제. 자격이 있어도 탈락시키는 조건. 없으면 null.",
          "examples": ["타 주거지원 사업 수혜 중인 자, 주택 소유자, 임대인이 가족인 경우"]
        },
        "link": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "신청/안내 URL. aplyUrlAddr→refUrlAddr1→RAG source_url 순. 모두 없으면 null."
        },
        "source": {
          "type": "string",
          "enum": ["api", "rag", "api+rag"],
          "description": "이 정책이 어느 경로에서 나왔는지. 하이브리드 추적용."
        }
      }
    },
    "criterion": {
      "type": "object",
      "required": ["label", "required", "user_value", "ok"],
      "additionalProperties": false,
      "description": "프로필로 판정한 자격 조건 1건. 이모지/배지/문장은 포맷터·카드에서 입힘. 데이터에는 넣지 않음.",
      "properties": {
        "label": {
          "type": "string",
          "enum": ["나이", "지역", "소득", "학력", "취업상태", "결혼상태", "전공", "특화분야", "주택소유"],
          "description": "조건 종류. 입력 프로필이 다양해지면 항목 추가."
        },
        "required": {
          "type": "string",
          "description": "정책이 요구하는 값.",
          "examples": ["19~49세", "경상북도 울릉군", "중위소득 150% 이하"]
        },
        "user_value": {
          "type": "string",
          "description": "사용자 프로필 값. 미입력 시 '미입력'.",
          "examples": ["27세", "서울", "미입력"]
        },
        "ok": {
          "type": "boolean",
          "description": "true=충족, false=미충족 또는 확인 불가."
        }
      }
    },
    "otherCondition": {
      "type": "object",
      "required": ["label", "required"],
      "additionalProperties": false,
      "description": "정책이 요구하지만 현재 판정하지 않는 조건. 판정 결과(ok)가 없는 게 criterion과의 차이.",
      "properties": {
        "label": {
          "type": "string",
          "description": "조건 종류. 코드 필드 기반(결혼상태/학력/취업상태/전공/특화분야) 또는 자유 문구는 '기타'.",
          "examples": ["결혼상태", "학력", "취업상태", "기타"]
        },
        "required": {
          "type": "string",
          "description": "정책이 요구하는 값.",
          "examples": ["미혼", "제한없음", "(예비)창업자", "무주택 청년"]
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["latency_ms", "query", "candidate_count", "matched_count", "api_path"],
      "additionalProperties": false,
      "properties": {
        "latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Agent 실행 소요 시간(ms)."
        },
        "query": {
          "type": "string",
          "description": "이 Agent가 실제로 사용한 검색 질의."
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0,
          "description": "API+RAG에서 모은 후보 정책 수(점수 필터 이전)."
        },
        "matched_count": {
          "type": "integer",
          "minimum": 0,
          "description": "score 임계값을 통과해 items에 포함된 수."
        },
        "api_path": {
          "type": "string",
          "enum": ["official", "legacy", "portal", "none"],
          "description": "ontong_api 3단 fallback 중 응답을 준 경로. none=API 전부 실패."
        },
        "region_unresolved": {
          "type": "integer",
          "minimum": 0,
          "description": "region 코드→한글 변환에 실패한 후보 수. 데이터 품질 신호."
        }
      }
    }
  }
}
